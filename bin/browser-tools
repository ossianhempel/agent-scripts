#!/usr/bin/env bash
# Lightweight Chrome DevTools helpers (no MCP required).
# Resolves to scripts/browser-tools.ts so the canonical implementation stays in one place.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
script="$here/../scripts/browser-tools.ts"

if command -v tsx >/dev/null 2>&1; then
  exec tsx "$script" "$@"
elif command -v bun >/dev/null 2>&1; then
  exec bun "$script" "$@"
elif command -v npx >/dev/null 2>&1; then
  exec npx --yes tsx "$script" "$@"
else
  echo "bin/browser-tools: needs tsx, bun, or npx (none found)" >&2
  exit 127
fi
