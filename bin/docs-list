#!/usr/bin/env bash
# Discover docs/ — prints summary + read_when for every doc.
# Resolves to scripts/docs-list.ts so the canonical implementation stays in one place.
set -euo pipefail

here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
script="$here/../scripts/docs-list.ts"

if command -v tsx >/dev/null 2>&1; then
  exec tsx "$script" "$@"
elif command -v bun >/dev/null 2>&1; then
  exec bun "$script" "$@"
elif command -v npx >/dev/null 2>&1; then
  exec npx --yes tsx "$script" "$@"
else
  echo "bin/docs-list: needs tsx, bun, or npx (none found)" >&2
  exit 127
fi
