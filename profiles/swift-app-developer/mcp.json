{
  "mcpServers": {
    "xcodebuildmcp": {
      "command": "npx",
      "args": ["-y", "xcodebuildmcp@latest", "mcp"],
      "env": {
        "XCODEBUILDMCP_ENABLED_WORKFLOWS": "simulator"
      }
    },
    "revenuecat": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.revenuecat.ai/mcp"]
    }
  }
}
