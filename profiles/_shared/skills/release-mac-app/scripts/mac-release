#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${BASH_VERSION:-}" && "${BASH_VERSINFO[0]:-0}" -lt 4 && -x /opt/homebrew/bin/bash ]]; then
  exec /opt/homebrew/bin/bash "$0" "$@"
fi

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

# Prefer Apple's system Python for appcast XML parsing. Homebrew Python can be
# ahead of the macOS libexpat on this machine, which breaks ElementTree imports.
export PATH="/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

if [[ -n "${MAC_RELEASE_SPARKLE_BIN_DIR:-}" && -d "$MAC_RELEASE_SPARKLE_BIN_DIR" ]]; then
  export PATH="$MAC_RELEASE_SPARKLE_BIN_DIR:$PATH"
else
  for sparkle_bin in \
    "$PWD/.build/artifacts/sparkle/Sparkle/bin" \
    "$PWD/.build/index-build/artifacts/sparkle/Sparkle/bin"; do
    if [[ -x "$sparkle_bin/generate_appcast" ]]; then
      export PATH="$sparkle_bin:$PATH"
      break
    fi
  done
fi

# shellcheck source=/Users/ossianhempel/Developer/agent-scripts/profiles/_shared/skills/release-mac-app/scripts/lib/mac_release.sh
source "$SCRIPT_DIR/lib/mac_release.sh"

cmd=${1:-status}
shift || true

case "$cmd" in
  status)
    mac_release_status "$@"
    ;;
  notes|generate-release-notes)
    mac_release_load
    version=${1:-$MARKETING_VERSION}
    out=${2:-}
    if [[ -z "$out" ]]; then
      tmp=$(mktemp "/tmp/${APP_NAME}-notes.XXXXXX")
      extract_notes_from_changelog "$version" "$tmp"
      cat "$tmp"
      rm -f "$tmp"
    else
      extract_notes_from_changelog "$version" "$out"
    fi
    ;;
  changelog-html|changelog-to-html)
    mac_release_changelog_html "$@"
    ;;
  make-appcast|appcast)
    mac_release_make_appcast "$@"
    ;;
  verify-appcast)
    mac_release_verify_appcast "$@"
    ;;
  check-assets)
    mac_release_load
    check_assets "${1:-$(git describe --tags --abbrev=0)}" "$ARTIFACT_PREFIX"
    ;;
  sparkle-key-status)
    mac_release_sparkle_key_status "$@"
    ;;
  codesign-run)
    mac_release_codesign_run "$@"
    ;;
  --public-key)
    mac_release_load
    mac_release_public_key_for_source "${1:-keychain}"
    ;;
  --expected-public-key)
    mac_release_expected_public_key
    ;;
  release)
    mac_release_release "$@"
    ;;
  *)
    cat >&2 <<'EOF'
Usage: mac-release <command>

Commands:
  status
  notes [version] [output.md]
  changelog-html <version> [CHANGELOG.md]
  make-appcast <zip> [feed-url]
  verify-appcast [version]
  check-assets [tag]
  sparkle-key-status [keychain|/path/to/key]
  codesign-run [--with-package-secrets] -- <command> [args...]
  release
EOF
    exit 2
    ;;
esac
