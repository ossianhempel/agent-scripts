#!/usr/bin/env bash
set -euo pipefail

# ios-release — manifest-driven helper for the release-ios-app skill.
# Reads the repo-owned .ios-release.env and reports release readiness signals.
# Heavy lifting (build/sign/upload/submit) stays in repo scripts and asc/eas/xcodebuild.

die() { echo "ERROR: $*" >&2; exit 1; }

repo_root() { git rev-parse --show-toplevel 2>/dev/null || pwd; }

load_manifest() {
  local root manifest
  root=$(repo_root)
  manifest="$root/.ios-release.env"
  [[ -f "$manifest" ]] || die "No .ios-release.env in $root (is this an iOS app repo with release-ios-app set up?)"
  # shellcheck disable=SC1090
  set -a; source "$manifest"; set +a
  MANIFEST_ROOT="$root"
  : "${IOS_RELEASE_APP_ID:?Set IOS_RELEASE_APP_ID in .ios-release.env}"
  : "${IOS_RELEASE_VERSION_SOURCE:?Set IOS_RELEASE_VERSION_SOURCE in .ios-release.env}"
  IOS_RELEASE_APPSTORE_LOOKUP_COUNTRY=${IOS_RELEASE_APPSTORE_LOOKUP_COUNTRY:-us}
}

# Current marketing version from the version source (project.yml / app.json / app.config.*).
current_version() {
  local src="$MANIFEST_ROOT/$IOS_RELEASE_VERSION_SOURCE"
  [[ -f "$src" ]] || die "Version source not found: $src"
  case "$src" in
    *.json)
      /usr/bin/python3 - "$src" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
v = (d.get("expo") or {}).get("version") or d.get("version")
print(v or "")
PY
      ;;
    *)
      # project.yml / xcconfig style: first MARKETING_VERSION value
      grep -Eo 'MARKETING_VERSION[[:space:]]*[:=][[:space:]]*"?[0-9]+(\.[0-9]+)*"?' "$src" \
        | head -n1 | grep -Eo '[0-9]+(\.[0-9]+)*'
      ;;
  esac
}

# Live App Store version via Apple's public lookup API. Empty if unavailable / unreleased.
live_version() {
  local cc="$IOS_RELEASE_APPSTORE_LOOKUP_COUNTRY"
  command -v curl >/dev/null 2>&1 || { echo ""; return 0; }
  local json
  json=$(curl -fsS "https://itunes.apple.com/lookup?id=${IOS_RELEASE_APP_ID}&country=${cc}" 2>/dev/null) || { echo ""; return 0; }
  printf '%s' "$json" | /usr/bin/python3 -c 'import json,sys
try:
    d=json.load(sys.stdin); r=d.get("results") or []
    print(r[0].get("version","") if r else "")
except Exception:
    print("")'
}

# Return 0 if $1 > $2 (dotted numeric). Equal or lower → non-zero.
version_gt() {
  [[ "$1" != "$2" ]] || return 1
  local hi
  hi=$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -n1)
  [[ "$hi" == "$1" ]]
}

cmd_live_version() { load_manifest; live_version; }

cmd_status() {
  load_manifest
  local cur live
  cur=$(current_version || true)
  live=$(live_version || true)
  echo "app:           $IOS_RELEASE_APP_ID  (${IOS_RELEASE_BUNDLE_ID:-?})"
  echo "build system:  ${IOS_RELEASE_BUILD_SYSTEM:-?}"
  echo "version source: $IOS_RELEASE_VERSION_SOURCE"
  echo "branches:      beta=${IOS_RELEASE_BETA_BRANCH:-?} -> release=${IOS_RELEASE_RELEASE_BRANCH:-?}"
  echo "backend:       ${IOS_RELEASE_BACKEND_DEPLOY:-none}"
  echo "current version: ${cur:-<unparsed>}"
  echo "live App Store:  ${live:-<none / unavailable>}"
  if [[ -n "$cur" && -n "$live" ]]; then
    if version_gt "$cur" "$live"; then
      echo "gate:          OK ($cur > $live)"
    else
      echo "gate:          BLOCKED ($cur is not > live $live — bump before pushing the release train)"
    fi
  else
    echo "gate:          (skipped — missing current or live version)"
  fi
  [[ -n "${IOS_RELEASE_NOTES_FILE:-}" ]] && echo "repo notes:    $IOS_RELEASE_NOTES_FILE (read before release moves)"
  return 0
}

cmd_check_version() {
  load_manifest
  local cur="${1:-}" live
  [[ -n "$cur" ]] || cur=$(current_version || true)
  [[ -n "$cur" ]] || die "Could not determine current version; pass it explicitly"
  live=$(live_version || true)
  if [[ -z "$live" ]]; then
    echo "No live App Store version found (unreleased or lookup unavailable); gate passes for $cur."
    return 0
  fi
  if version_gt "$cur" "$live"; then
    echo "OK: $cur > live $live"
  else
    die "Version gate failed: $cur is not greater than live App Store version $live"
  fi
}

cmd=${1:-status}; shift || true
case "$cmd" in
  status)        cmd_status "$@" ;;
  check-version) cmd_check_version "$@" ;;
  live-version)  cmd_live_version "$@" ;;
  *)
    cat >&2 <<'EOF'
Usage: ios-release <command>

Commands:
  status                 Show app/build-system/branch/version summary and the version gate.
  check-version [ver]    Fail if the (given or current) version is not > the live App Store version.
  live-version           Print the live App Store version (Apple public lookup).
EOF
    exit 2 ;;
esac
